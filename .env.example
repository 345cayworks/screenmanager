# =============================================================================
# Required — the app will not boot without these.
# =============================================================================

# Database connection string.
#   Local dev (SQLite): file:./dev.db
#   Production (Postgres / Neon / Netlify DB): postgres://USER:PASS@HOST/DB
DATABASE_URL=file:./dev.db

# Signs session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# OptiSigns API key — server-only, NEVER exposed to the browser.
OPTISIGNS_API_KEY=

# OptiSigns GraphQL endpoint.
OPTISIGNS_GRAPHQL_ENDPOINT=https://graphql-gateway.optisigns.com/graphql

# =============================================================================
# Required ONLY when running `npm run db:seed` — used to provision the
# bootstrap SUPERADMIN account. Not read by the app at runtime.
# =============================================================================

SUPER_ADMIN_EMAIL=admin@yourcompany.com
SUPERADMIN_MASTER_KEY=use-a-long-random-passphrase-min-12-chars

# =============================================================================
# Optional.
# =============================================================================

# Display name for the seeded superadmin (default: "Super Admin")
SUPER_ADMIN_NAME=Super Admin

# Set to "true" to also seed the Acme demo client + demo users on `db:seed`.
SEED_DEMO_DATA=false

# Branding shown in the browser tab and login screen.
NEXT_PUBLIC_APP_NAME=OptiSigns Client Playlist Portal
