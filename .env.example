# OptiSigns API (server-only — never expose to the frontend)
OPTISIGNS_API_KEY=
OPTISIGNS_GRAPHQL_ENDPOINT=https://graphql-gateway.optisigns.com/graphql

# Database
# For local development with SQLite, use: file:./dev.db
# For Postgres (Netlify DB / Neon / Supabase), use a postgres:// connection string.
DATABASE_URL=file:./dev.db

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# App
NEXT_PUBLIC_APP_NAME=OptiSigns Client Playlist Portal
